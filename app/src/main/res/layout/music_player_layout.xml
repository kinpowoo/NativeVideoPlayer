<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <android.opengl.GLSurfaceView
        android:id="@+id/blur_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


    <ImageView
        android:id="@+id/dismiss_btn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/ic_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/song_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:maxLines="2"
        android:singleLine="false"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@+id/more_opt_btn"
        app:layout_constraintStart_toEndOf="@+id/dismiss_btn"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/more_opt_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="15dp"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_more_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:tint="@color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/cover"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar" />


    <ImageView
        android:id="@+id/voice_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="15dp"
        android:src="@drawable/baseline_volume_up_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cover" />


    <com.jhkj.videoplayer.components.VerticalVolumeSeekBar
        android:id="@+id/volume_slider"
        android:visibility="gone"
        android:layout_marginStart="5dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@+id/voice_btn"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="20dp"
        android:layout_height="150dp"/>
    <ImageView
        android:id="@+id/fav_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="30dp"
        android:src="@drawable/outline_favorite_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cover" />

    <TextView
        android:id="@+id/track_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="10dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/voice_btn" />

    <ImageView
        android:id="@+id/inner_circle"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_border"
        app:layout_constraintBottom_toBottomOf="@+id/play_progress"
        app:layout_constraintEnd_toEndOf="@+id/play_progress"
        app:layout_constraintStart_toStartOf="@+id/play_progress"
        app:layout_constraintTop_toTopOf="@+id/play_progress" />

    <com.jhkj.videoplayer.components.CircleSeekBar
        android:id="@+id/play_progress"
        android:layout_width="210dp"
        android:layout_height="210dp"
        android:layout_marginTop="19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/track_info" />

    <ImageView
        android:id="@+id/play_btn_bg"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/dark_light_gray_circle"
        app:layout_constraintBottom_toBottomOf="@+id/play_progress"
        app:layout_constraintEnd_toEndOf="@+id/play_progress"
        app:layout_constraintStart_toStartOf="@+id/play_progress"
        app:layout_constraintTop_toTopOf="@+id/play_progress" />

    <ImageView
        android:id="@+id/start_btn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/dark_gray_circle"
        android:src="@drawable/baseline_play_arrow_24"
        app:layout_constraintBottom_toBottomOf="@+id/play_progress"
        app:layout_constraintEnd_toEndOf="@+id/play_progress"
        app:layout_constraintStart_toStartOf="@+id/play_progress"
        app:layout_constraintTop_toTopOf="@+id/play_progress" />

    <ImageView
        android:id="@+id/backward_30"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/sharp_fast_rewind_24"
        app:layout_constraintBottom_toBottomOf="@+id/play_progress"
        app:layout_constraintEnd_toStartOf="@+id/play_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/play_progress" />

    <ImageView
        android:id="@+id/forward_30"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/baseline_fast_forward_24"
        app:layout_constraintBottom_toBottomOf="@+id/play_progress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/play_progress"
        app:layout_constraintTop_toTopOf="@+id/play_progress" />


    <TextView
        android:id="@+id/cur_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="3dp"
        android:text="@string/song_init_time"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/start_btn"
        app:layout_constraintEnd_toStartOf="@+id/play_btn_bg"
        app:layout_constraintStart_toStartOf="@+id/inner_circle"
        app:layout_constraintTop_toTopOf="@+id/start_btn" />


    <TextView
        android:id="@+id/total_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="3dp"
        android:text="@string/song_init_time"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/start_btn"
        app:layout_constraintEnd_toEndOf="@+id/inner_circle"
        app:layout_constraintStart_toEndOf="@+id/play_btn_bg"
        app:layout_constraintTop_toTopOf="@+id/start_btn" />
</androidx.constraintlayout.widget.ConstraintLayout>